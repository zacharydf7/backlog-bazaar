# ---------------------------------------------------------------------------
# Game data (optional). With a RAWG key, searching auto-fills length, rating,
# and cover art. Without it the app falls back to keyless Wikidata search.
# Get a free key at https://rawg.io/apidocs (sign up -> "Get API Key").
# ---------------------------------------------------------------------------
VITE_RAWG_KEY=

# ---------------------------------------------------------------------------
# User accounts + sync + leaderboard (Supabase). Without these, the app runs
# locally with no login. Create a free project at https://supabase.com, then
# find these under Project Settings -> API.
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
